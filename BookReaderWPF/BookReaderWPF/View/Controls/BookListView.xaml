<UserControl x:Class="BookReader.View.BookListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:BookReader.View">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10" Background="#FAFAFA">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Grid Width="220" Margin="0,0,20,5">
                    <TextBox x:Name="SearchBox" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="25,4,4,4" VerticalContentAlignment="Center" Background="White" BorderBrush="#CCCCCC"/>
                    <TextBlock Text="🔍" Foreground="Gray" VerticalAlignment="Center" Margin="6,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="Search title or author..." Foreground="DarkGray" IsHitTestVisible="False" VerticalAlignment="Center" Margin="28,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="TAG" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,8,5" FontSize="11" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding AvailableTags}" SelectedItem="{Binding SelectedTag}" Width="130" Margin="0,0,20,5" Padding="4"/>

                <TextBlock Text="STATUS" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,8,5" FontSize="11" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Width="120" Margin="0,0,20,5" Padding="4"/>

                <TextBlock Text="RATING" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,8,5" FontSize="11" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Ratings}" SelectedItem="{Binding SelectedRating}" Width="100" Margin="0,0,20,5" Padding="4"/>

                <TextBlock Text="SORT" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,8,5" FontSize="11" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" Width="100" Margin="0,0,20,5" Padding="4"/>

                <Button Command="{Binding ClearFiltersCommand}" Content="✖ Clear" 
                        Visibility="{Binding ClearFiltersVisibility}" 
                        Background="Transparent" Foreground="#D32F2F" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,0,5" Padding="10,0"/>
            </WrapPanel>
        </Border>

        <ListBox Grid.Row="1" x:Name="booksList" ItemsSource="{Binding FilteredBooks}" SelectedItem="{Binding SelectedBook}"
                 BorderThickness="0" Background="White" Padding="10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListBox.InputBindings>
                <!-- Nadpisanie skrótu Ctrl+A, bo ListBox domyślnie go używa (natwynie) -->
                <KeyBinding Key="A" Modifiers="Control" Command="{Binding AddBookCommand}" />
            </ListBox.InputBindings>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid>
                                    <Rectangle x:Name="SelectionBorder" Stroke="Transparent" StrokeThickness="2" RadiusX="4" RadiusY="4"/>

                                    <Border Background="White" Margin="4">
                                        <ContentPresenter />
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="SelectionBorder" Property="Stroke" Value="{StaticResource AccentColorBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical" Width="130" Cursor="Hand" Background="Transparent" Margin="8">
                        <StackPanel.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding DataContext.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        </StackPanel.InputBindings>

                        <Border BorderBrush="#E0E0E0" BorderThickness="1" Background="#F0F0F0" Height="200">
                            <Image Source="{Binding CoverBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="Uniform" />
                        </Border>

                        <TextBlock Text="{Binding Title}" Foreground="Black" FontSize="14" FontFamily="Arial" FontWeight="SemiBold" Margin="0,8,0,2" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Author}" Foreground="Gray" FontSize="12" FontFamily="Arial" TextTrimming="CharacterEllipsis"/>

                        <views:RatingControl Value="{Binding Rating}" IsReadOnly="True" StarSize="24" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>