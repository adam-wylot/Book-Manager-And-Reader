<UserControl x:Class="BookReader.View.BookDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:BookReader.View">

    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20,30,30">

                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,20">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="← back to library" Foreground="{StaticResource AccentColorBrush}" FontFamily="Arial" FontSize="14" FontWeight="SemiBold"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" Width="220" Height="330" VerticalAlignment="Top">
                        <Image Source="{Binding Book.CoverBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="30,0,0,0">
                        <TextBlock Text="{Binding Book.Title}" FontSize="28" FontWeight="Bold" Foreground="Black" FontFamily="Arial"/>
                        <TextBlock Text="{Binding Book.Author}" FontSize="16" Foreground="Gray" FontFamily="Arial" Margin="0,5,0,0" />
                        <views:RatingControl Value="{Binding Book.Rating}" IsReadOnly="True" StarSize="24" Margin="0,0,0,30" />

                        <TextBlock Text="DESCRIPTION" Foreground="Gray" FontSize="12" FontFamily="Arial" FontWeight="Bold" Margin="0,0,0,8" Visibility="{Binding DescriptionVisibility}" />
                        <TextBlock Text="{Binding Book.Description}" TextWrapping="Wrap" FontSize="14" FontFamily="Arial" Foreground="#444" LineHeight="22" Visibility="{Binding DescriptionVisibility}" />

                        <TextBlock Text="TAGS" Foreground="Gray" FontSize="12" FontFamily="Arial" FontWeight="Bold" Margin="0,20,0,8" Visibility="{Binding TagsVisibility}" />
                        <views:TagControl Tags="{Binding DisplayTags}" IsEditable="False" ChipBackground="{StaticResource LighterColorBrush}" />

                        <!-- Reading progress -->
                        <StackPanel Visibility="{Binding ReadingProgressVisibility}" Margin="0,20,0,0">
                            <TextBlock Text="READING PROGRESS" Foreground="Gray" FontSize="12" FontFamily="Arial" FontWeight="Bold" Margin="0,0,0,8" />
                            
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ProgressBar Value="{Binding Book.CurrentPage}" Maximum="{Binding Book.TotalPages}" 
                                             Width="200" Height="8" Margin="0,0,15,0" 
                                             Foreground="{StaticResource AccentColorBrush}" Background="#E0E0E0" BorderThickness="0" />
                                <TextBlock Foreground="#444" FontSize="14" FontFamily="Arial" FontWeight="SemiBold">
                                    <Run Text="Chapter "/>
                                    <Run Text="{Binding Book.CurrentPage, Mode=OneWay}" />
                                    <Run Text=" of " Foreground="Gray" />
                                    <Run Text="{Binding Book.TotalPages, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Przyciski -->
                        <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                            <Button Command="{Binding EditBookCommand}" Style="{StaticResource FlatButton}" Background="{StaticResource DarkerColorBrush}" Width="80" Margin="0,0,15,0" Height="30">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✏️ "/>
                                    <TextBlock Text="Edit..."/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ReadFromStartCommand}" 
                                    Visibility="{Binding ReadFromStartVisibility}" 
                                    Style="{StaticResource FlatButton}" 
                                    Width="160" Margin="0,0,15,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📖 "/>
                                    <TextBlock Text="Read from Beginning"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ContinueReadingCommand}" 
                                    Visibility="{Binding ContinueReadingVisibility}" 
                                    Style="{StaticResource FlatButton}" 
                                    Background="{StaticResource AccentColorBrush}" 
                                    Width="140">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶ "/>
                                    <TextBlock Text="Continue Reading"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>