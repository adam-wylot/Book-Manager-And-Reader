<Window x:Class="BookReader.View.ReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BookReader.View"
        
        Title="{Binding WindowTitle}" 
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner" Background="White"
        Icon="/Resources/book.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pasek nawigacji -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColorBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding PreviousCommand}" Content="← Previous" 
                        Style="{StaticResource FlatButton}" Background="{StaticResource DarkerColorBrush}" Width="120" Height="35"/>

                <TextBlock Grid.Column="1" Text="{Binding ProgressText}" 
                           Foreground="White" FontSize="16" FontFamily="Arial" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="2" Command="{Binding NextCommand}" Content="Next →" 
                        Style="{StaticResource FlatButton}" Background="{StaticResource AccentColorBrush}" Width="120" Height="35"/>
            </Grid>
        </Border>

        <!-- Treść książki -->
        <WebBrowser
            x:Name="Browser" 
            Grid.Row="1" 
            views:WebBrowserBehavior.BindableSource="{Binding CurrentChapterUrl}" 
            Margin="10" 
            LoadCompleted="Browser_LoadCompleted" />
    </Grid>
</Window>